proc main() {
    var fd = open("/proc/self/args");
    if (fd >= 0) {
        var buf = sbrk(1024);
        read(fd, buf);
        var length = strlen(buf);
        var i = 0;
        while (i < length) {
            if (read_byte(buf + i) == 10) {
                write_byte(buf + i, 32);
            }
            i = i + 1;
        }
        println(buf);
    }
}
